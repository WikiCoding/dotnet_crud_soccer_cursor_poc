{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "SoccerDb": "Host=localhost;Port=5555;Database=soccer-db;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "RedisCache": {
    "DefaultTtlSeconds": 60,
    "CircuitBreaker": {
      "FailureRatio": 0.5, // 50% of calls must fail before the circuit breaker opens
      "SamplingDurationSeconds": 10, // 10 seconds window to evaluate the failure ratio
      "MinimumThroughput": 3, // 3 calls must be made before the failure ratio is evaluated
      "BreakDurationSeconds": 30 // 30 seconds to wait before trying again
    }
  }
}
